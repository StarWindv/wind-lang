` 这里是一个行注释

const hello: string = "hello, world!";

const data: map = {
    "key_1" : "value_1",
};
const array : vec<string> = [ "hello", "world" ];

constatic static_value: int = 666;

pub fn test(input: string) -> None {
    builtins::output(input);
}

public trait DisplayJson {
    fn str(self) -> string;
}

pub struct TestStruct {
    pub data: map;
}


impl DisplayJson for TestStruct {
    pub fn str(self) -> string {
        result: string = "{\n";
        for (kv: self.entry()) {
            result += "\"{kv.key}\": \"{kv.value}\"".format()
            if ( kv == self.get_last() ) {
                result += "\n}"
            } else {
                result += ",\n"
            }
        }
        return result;
    }
}

extra obtain: TestStruct {
    pub fn get(self, possible_key: string) -> string {
        if ( possible in self.data ) {
            return self.data[possible_key];
        } return "";
    }
}

type Email = string where {
    self.length >= 5 && self.length < 20;
    self.matches("@[a-zA-Z]+\\.[a-zA-Z]+");
}
type Name  = string where {
    self.length > 1 && self.length < 10;
}
struct User {
    pub email: Email;
    pub name : Name;
    pub uid  : int where { uid.length == 11 };
    pub age  : int -> { age > 0 && age < 65 };
    static uid_counter: int = 0;
}


extra User {
    pub fn new(
        email: string,
        name : string,
        age  : int
    ) -> Self {
        return User {
            email, name, Self::uid_counter, age
        };
    }

    fn growth() -> None, which ::new {
        Self::uid_counter++;
    }

    fn str(self) -> String {
        return "\
Name : {self.name}\n\
Age  : {self.age}\n\
UID  : {self.uid}\n\
Email: {self.email}\n\
".format();
    }
}

group Dispenser(a: string, b: string) {
    a -> Name;
    b -> Email;
}
Despenser@User -> {name, email}

group Dispenser_2: User {
    self.name  -> Name;
    self.email -> Email;
}

fn main(args: vec<string>) -> int {
    admin = User::new(
        "admin@wind-lang.top",
        "admin",
         9 + 9 * 2 / 3 + 3
    );
    me <: admin;
    output(admin);
    output(me);
    ` or: output(admin.str());
}

to abcdefg;
a = 5;
